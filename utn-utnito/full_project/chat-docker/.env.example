# Compose project
COMPOSE_PROJECT_NAME=utn-utnito

# Reserved host ports (chosen to avoid collisions with existing local projects)
FRONTEND_PORT=4300
CORE_SERVICE_PORT=4012
N8N_PORT=5690

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=utn_ai_admin
N8N_BASIC_AUTH_PASSWORD=utn_ai_admin_password
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires

# AI provider (chat-core-service)
AI_PROVIDER=mock
AI_ON_ERROR_FALLBACK=mock
AI_ASSISTANT_NAME=UTNito
AI_ASSISTANT_DESCRIPTION=an AI assistant for a university programming course
AI_ASSISTANT_PERSONALITY=friendly, clear, and practical programming mentor
AI_CONTEXT_MAX_PAIRS=5
AI_N8N_WEBHOOK_URL=http://chat-n8n:5678/webhook/utnito-prompt-processing
AI_N8N_TIMEOUT_MS=15000
